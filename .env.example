# ==========================================
# Steel City AI - Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ==========================================
# REQUIRED: Database Configuration (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://username:password@localhost:5432/steelcity_ai
PGHOST=localhost
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGDATABASE=steelcity_ai

# ==========================================
# REQUIRED: Session Security
# ==========================================
# Generate a random 32+ character hex string:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-super-secret-session-key-minimum-32-characters-long

# ==========================================
# SERVER
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# REQUIRED: Bot Protection (Cloudflare Turnstile)
# Required for Contact and Consultation form submissions.
# Create a Turnstile site at https://dash.cloudflare.com/?to=/:account/turnstile
# ==========================================
TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key-here

# ==========================================
# AI INTEGRATION: OpenRouter (for Automation Outlines)
# Required for AI-powered automation discovery questionnaire.
# Get API key at https://openrouter.ai/keys
# ==========================================
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ==========================================
# AI INTEGRATION: Google Gemini (for Chatbot & Live Chat)
# Required for chatbot responses and AI features.
# Get API key from Google AI Studio: https://makersuite.google.com/app/apikey
# ==========================================
AI_INTEGRATIONS_GEMINI_API_KEY=your-gemini-api-key-here
# Optional: AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ==========================================
# AI INTEGRATION: OpenAI (Optional - alternative provider)
# ==========================================
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-openai-api-key
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================
# EMAIL INTEGRATION: Gmail API (Optional)
# Required for sending email notifications on form submissions.
# Format: JSON string with OAuth credentials
# ==========================================
# GOOGLE_OAUTH_SECRETS={"client_id":"...","client_secret":"...","refresh_token":"..."}

# ==========================================
# ANALYTICS (Optional)
# ==========================================
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
